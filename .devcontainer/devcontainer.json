{
    "name": "my-deply-third-party-plugin",
    "build": {
        "context": "..",
        "dockerfile": "Dockerfile"
    },
    "customizations": {
        "vscode": {
            "extensions": [
                "ms-python.python",
                "ms-python.vscode-pylance",
                "ms-python.debugpy",
                "charliermarsh.ruff",
                "ms-azuretools.vscode-containers",
                "tamasfe.even-better-toml",
                "eamodio.gitlens",
                "GitHub.copilot",
                "github.vscode-github-actions",
                "redhat.vscode-yaml",
                "mechatroner.rainbow-csv",
                "Gruntfuggly.todo-tree"
            ]
        }
    },
    "containerEnv": {
        "APP_NAME": "MY_DEPLY_PLUGIN"
    },
    "postCreateCommand": "uv sync --all-groups",
    "remoteUser": "vscode"
}
